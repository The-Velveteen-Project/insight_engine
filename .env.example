# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_ADMIN_CHAT_ID=0
TELEGRAM_COMMAND_LIMIT=3

# OpenAI (Phase 6 — leave empty for now)
OPENAI_API_KEY=
EDITORIAL_MODEL=gpt-4.1-mini

# Discovery
DISCOVERY_DEFAULT_LIMIT=3
DISCOVERY_FETCH_MULTIPLIER=4
DISCOVERY_ENABLED_SOURCES=arxiv,hackernews

# GitHub
GITHUB_TOKEN=
GITHUB_INSIGHTS_DEFAULT_LIMIT=5
GITHUB_COMMITS_LIMIT=8
PRIORITY_GITHUB_REPOS=The-Velveteen-Project/StochastoGreen,The-Velveteen-Project/EcoAgent

# Scheduler
ENABLE_SCHEDULER=false
WEEKLY_DISCOVERY_QUERY=agentic workflows climate risk health ai latam applied research
WEEKLY_SUMMARY_CRON=0 9 * * 0
WEEKLY_MVP_SCAN_CRON=0 9 * * 4

# Database
DB_PATH=data/engine.db

# App
DEBUG=false
LOG_LEVEL=INFO
