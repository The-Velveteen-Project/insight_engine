# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_ADMIN_CHAT_ID=0
TELEGRAM_COMMAND_LIMIT=3
TELEGRAM_MAX_MESSAGE_CHARS=4096
TELEGRAM_SEND_RETRIES=2
INTERNAL_CRON_SECRET=

# OpenAI (or any OpenAI-compatible endpoint via OPENAI_BASE_URL).
# Editorial / draft / weekly thesis / linkedin / handoff match all run
# through this client. Whisper transcription stays on OpenAI native.
#
# Examples for the override:
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
#               EDITORIAL_MODEL=anthropic/claude-3.5-sonnet
#   Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1
#               EDITORIAL_MODEL=llama-3.3-70b-versatile
#   Ollama:     OPENAI_BASE_URL=http://localhost:11434/v1
#               EDITORIAL_MODEL=qwen2.5:14b
OPENAI_API_KEY=
OPENAI_BASE_URL=
EDITORIAL_MODEL=gpt-4.1-mini

# Anthropic — query normalization via Claude Haiku (cheap, non-fatal if absent)
ANTHROPIC_API_KEY=
NORMALIZER_MODEL=claude-haiku-4-5
NORMALIZER_TIMEOUT_SECONDS=3.0
NORMALIZER_CACHE_SIZE=128

# Discovery
DISCOVERY_DEFAULT_LIMIT=3
DISCOVERY_FETCH_MULTIPLIER=4
# Default sources changed in Sub-phase B.6 (Exa replaces HN by default).
# To re-enable Hacker News alongside Exa, use: arxiv,exa,hackernews
DISCOVERY_ENABLED_SOURCES=arxiv,exa

# Exa (neural search) — get a key at https://dashboard.exa.ai
# Free tier covers ~1000 requests/month; weekly + ad-hoc usage stays well under.
EXA_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_INSIGHTS_DEFAULT_LIMIT=5
GITHUB_COMMITS_LIMIT=8
PRIORITY_GITHUB_REPOS=The-Velveteen-Project/StochastoGreen,The-Velveteen-Project/EcoAgent

# Supabase (planned Phase 2 persistence migration)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scheduler
ENABLE_SCHEDULER=false
WEEKLY_DISCOVERY_QUERY=agentic workflows climate risk health ai latam applied research
WEEKLY_SUMMARY_CRON=0 9 * * 0
WEEKLY_MVP_SCAN_CRON=0 9 * * 4

# Database
# For Railway with a mounted volume, prefer: /data/engine.db
DB_PATH=data/engine.db

# App
DEBUG=false
LOG_LEVEL=INFO
